# =============================================================================
# SRT Translator — Environment Configuration
# =============================================================================
# Copy this file to .env before running the app:
#   cp .env.example .env
#
# The app WILL NOT start without a .env file.
# All variables are prefixed with SRT_.
# =============================================================================


# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Environment mode: "development" or "production"
# - development: CORS allows localhost:5173 (Vite dev server), no secure cookies
# - production:  CORS uses SRT_DEPLOYMENT_URL, secure cookies enabled (HTTPS)
# The Dockerfile sets this to "production" automatically.
SRT_ENV=development


# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# Your production URL — only needed when SRT_ENV=production
# This is the origin where the app is served from.
# Example: https://srt.yourdomain.com
# In development this is ignored (localhost is used automatically).
# SRT_DEPLOYMENT_URL=https://srt.yourdomain.com

# ── Security ─────────────────────────────────────────────────────────────────
# Force secure cookies (requires HTTPS). Auto-enabled in production.
# Only set this if you need to override the automatic behavior.
# SRT_SECURE_COOKIES=false

# ── File Retention ───────────────────────────────────────────────────────────
# Files older than this many days are automatically deleted.
# The session cookie automatically lives 2 days longer than this value,
# so users never lose access to files that still exist.
# SRT_FILE_MAX_AGE_DAYS=7

# How often (in hours) to run the cleanup task
# SRT_CLEANUP_INTERVAL_HOURS=1

# ── Upload Limits ────────────────────────────────────────────────────────────
# Maximum file size per upload (in MB)
# SRT_MAX_UPLOAD_SIZE_MB=10

# Maximum number of files per upload request
# SRT_MAX_UPLOAD_COUNT=50

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Rate limits per session (format: "N/period" — e.g. "10/minute", "100/hour")
# SRT_UPLOAD_RATE_LIMIT=10/minute
# SRT_TRANSLATE_RATE_LIMIT=5/minute
# SRT_GENERAL_RATE_LIMIT=60/minute

# ── Data Directory ───────────────────────────────────────────────────────────
# Where uploaded and translated files are stored.
# Default: <project_root>/data — in Docker this is /app/data
# SRT_DATA_DIR=/app/data
